{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/blockquote",
  "version": "1.0.0",
  "title": "Blockquote",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/content-root",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "format-quote",
  "description": "Display a quote inside Flow forms.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "content": {
      "type": "string",
      "default": "A highlighted quote."
    },
    "cite": {
      "type": "string",
      "default": ""
    },
    "color": {
      "type": "string",
      "default": ""
    },
    "radius": {
      "type": "string",
      "default": ""
    },
    "iconSize": {
      "type": "number",
      "default": 20
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}
