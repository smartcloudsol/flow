{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/group",
  "version": "1.0.0",
  "title": "Group",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "editor-insertmore",
  "description": "Horizontal layout container for Flow Form fields.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "gap": {
      "type": "string",
      "default": "md"
    },
    "grow": {
      "type": "boolean",
      "default": false
    },
    "align": {
      "type": "string",
      "default": "center"
    },
    "justify": {
      "type": "string",
      "default": "flex-start"
    },
    "preventGrowOverflow": {
      "type": "boolean",
      "default": true
    },
    "wrap": {
      "type": "string",
      "default": "wrap"
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "logicType": "all",
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}
