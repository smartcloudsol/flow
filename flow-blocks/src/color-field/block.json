{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/color-field",
  "version": "1.0.0",
  "title": "Color picker field",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "editor-table",
  "description": "Color picker field for Flow Form.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "default": "color"
    },
    "label": {
      "type": "string",
      "default": "Color"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "closeOnColorSwatchClick": {
      "type": "boolean",
      "default": false
    },
    "disabled": {
      "type": "boolean",
      "default": false
    },
    "disallowInput": {
      "type": "boolean",
      "default": false
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "format": {
      "type": "string",
      "default": "hex"
    },
    "pointer": {
      "type": "boolean",
      "default": false
    },
    "size": {
      "type": "string"
    },
    "swatches": {
      "type": "array",
      "default": []
    },
    "swatchesPerRow": {
      "type": "number"
    },
    "withPicker": {
      "type": "boolean",
      "default": true
    },
    "withEyeDropper": {
      "type": "boolean",
      "default": false
    },
    "withPreview": {
      "type": "boolean",
      "default": true
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "logicType": "all",
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}
