{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/title",
  "version": "1.0.0",
  "title": "Title",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/content-root",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "heading",
  "description": "Display a heading inside Flow forms.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "content": {
      "type": "string",
      "default": "Section title"
    },
    "order": {
      "type": "number",
      "default": 2
    },
    "size": {
      "type": "string",
      "default": ""
    },
    "color": {
      "type": "string",
      "default": ""
    },
    "align": {
      "type": "string",
      "default": "left"
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}
