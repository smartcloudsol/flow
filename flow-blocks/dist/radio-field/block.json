{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/radio-field",
  "version": "1.0.0",
  "title": "Radio field",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "editor-table",
  "description": "Radio button group field for Flow Form.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "default": "radioChoice"
    },
    "label": {
      "type": "string",
      "default": "Radio"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "disabled": {
      "type": "boolean",
      "default": false
    },
    "size": {
      "type": "string"
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "autoContrast": {
      "type": "boolean",
      "default": false
    },
    "color": {
      "type": "string",
      "default": ""
    },
    "icon": {
      "type": "string",
      "default": ""
    },
    "iconColor": {
      "type": "string",
      "default": ""
    },
    "optionsText": {
      "type": "string",
      "default": "Option 1|option1\nOption 2|option2"
    },
    "optionsSource": {
      "type": "string",
      "default": "static",
      "enum": [
        "static",
        "api",
        "autocomplete"
      ]
    },
    "apiEndpoint": {
      "type": "string",
      "default": ""
    },
    "apiMethod": {
      "type": "string",
      "default": "GET"
    },
    "apiHeaders": {
      "type": "string",
      "default": "{}"
    },
    "apiParams": {
      "type": "string",
      "default": "{}"
    },
    "apiResponsePath": {
      "type": "string",
      "default": ""
    },
    "apiLabelPath": {
      "type": "string",
      "default": ""
    },
    "apiValuePath": {
      "type": "string",
      "default": ""
    },
    "cacheEnabled": {
      "type": "boolean",
      "default": true
    },
    "cacheTTL": {
      "type": "number",
      "default": 3600
    },
    "autocompleteMinChars": {
      "type": "number",
      "default": 2
    },
    "autocompleteDebounce": {
      "type": "number",
      "default": 300
    },
    "searchParam": {
      "type": "string",
      "default": "q"
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "logicType": "all",
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}