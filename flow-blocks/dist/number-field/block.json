{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/number-field",
  "version": "1.0.0",
  "title": "Number field",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "editor-table",
  "description": "Number input field for Flow Form.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "default": "number"
    },
    "label": {
      "type": "string",
      "default": "Number"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "disabled": {
      "type": "boolean",
      "default": false
    },
    "size": {
      "type": "string"
    },
    "inputSize": {
      "type": "string"
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "min": {
      "type": "number"
    },
    "max": {
      "type": "number"
    },
    "step": {
      "type": "number",
      "default": 1
    },
    "allowLeadingZeros": {
      "type": "boolean",
      "default": false
    },
    "allowedDecimalSeparators": {
      "type": "array",
      "default": []
    },
    "clampBehavior": {
      "type": "string",
      "default": "blur"
    },
    "decimalScale": {
      "type": "number"
    },
    "decimalSeparator": {
      "type": "string",
      "default": "."
    },
    "allowNegative": {
      "type": "boolean",
      "default": true
    },
    "allowDecimal": {
      "type": "boolean",
      "default": true
    },
    "fixedDecimalScale": {
      "type": "boolean",
      "default": false
    },
    "hideControls": {
      "type": "boolean",
      "default": false
    },
    "prefix": {
      "type": "string",
      "default": ""
    },
    "startValue": {
      "type": "number"
    },
    "suffix": {
      "type": "string",
      "default": ""
    },
    "thousandSeparator": {
      "type": "string",
      "default": ""
    },
    "thousandsGroupStyle": {
      "type": "string",
      "default": "none"
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "logicType": "all",
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}