    },
    "fallbackToRawText": {
      "type": "boolean",
      "default": true
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "rules": []
      }
    },
    "continueDescription": {
      "type": "string",
      "default": ""
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false
  }
}