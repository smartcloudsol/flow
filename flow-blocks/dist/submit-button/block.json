{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smartcloud-flow/submit-button",
  "version": "1.0.0",
  "title": "Submit button",
  "category": "smartcloud-flow",
  "parent": [
    "smartcloud-flow/form",
    "smartcloud-flow/stack",
    "smartcloud-flow/group",
    "smartcloud-flow/grid",
    "smartcloud-flow/fieldset",
    "smartcloud-flow/collapse",
    "smartcloud-flow/visually-hidden",
    "smartcloud-flow/wizard-step"
  ],
  "icon": "button",
  "description": "Submit button for Flow Form.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "label": {
      "type": "string",
      "default": "Submit"
    },
    "showTitle": {
      "type": "boolean",
      "default": true
    },
    "showIcon": {
      "type": "boolean",
      "default": false
    },
    "iconPosition": {
      "type": "string",
      "default": "left"
    },
    "customIcon": {
      "type": "string",
      "default": ""
    },
    "conditionalLogic": {
      "type": "object",
      "default": {
        "enabled": false,
        "rules": []
      }
    },
    "hidden": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "smartcloud-flow-blocks-editor-script"
}