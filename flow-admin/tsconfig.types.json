{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./build/types",
    "rootDir": "./src",
    "stripInternal": true
  },
  "include": [
    "src/editor-runtime.ts",
    "src/operations-runtime.tsx",
    "src/vite-env.d.ts"
  ],
  "exclude": ["dist", "build", "node_modules"]
}
